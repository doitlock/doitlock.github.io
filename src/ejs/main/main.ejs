    <!-- tech Section -->
    <section class="tech" aria-label="행사 장소">
        <div class="tech__container">
            <h2 class="tech__title">TECH STACK</h2>
            <div class="tech__grid">
                <div class="tech__info">
                    <div class="tech__item">
                        <h4 class="tech__item-title">Core Markup & UI</h4>
                        <p class="tech__item-text">
                            HTML5, CSS3, SCSS, JavaScript / jQuery<br>
                            - 시멘틱 마크업, 접근성 고려 구조 설계<br>
                            - 모듈화, 공통 컴포넌트 스타일 관리<br>
                            - UI 인터랙션 구현
                        </p>
                    </div>
                    <div class="tech__item">
                        <h4 class="tech__item-title">Animation Libraries</h4>
                        <p class="tech__item-text">
                            GSAP, Swiper, Lenis<br>
                            - scrolltrigger<br>
                            - 슬라이드 반응형, 커스텀 컨트롤<br>
                            - 스크롤 UI
                        </p>
                    </div>
                    <div class="tech__item">
                        <h4 class="tech__item-title">Version Control & Collaboration</h4>
                        <p class="tech__item-text">
                            Git (GitHub, GitLab)<br>
                            Slack, Jira, Trello, Notion<br>
                                - 개발자 협업 환경에서 브랜치, 커밋 단위 작업<br>
                                - 이슈 관리 및 협업 커뮤니케이션
                        </p>
                    </div>
                    <div class="tech__item">
                        <h4 class="tech__item-title">Design tools</h4>
                        <p class="tech__item-text">
                            Figma, Adobe XD, PhotoShop
                        </p>
                    </div>
                    <div class="tech__item">
                        <h4 class="tech__item-title">IDE / Editor</h4>
                        <p class="tech__item-text">
                            Visual Studio Code, IntelliJ IDEA, eclipse
                        </p>
                    </div>
                    <div class="tech__item">
                        <h4 class="tech__item-title">Build</h4>
                        <p class="tech__item-text">
                            gulp(세팅 경험), Node.js
                        </p>
                    </div>
                </div>
            </div>
            <div class="tech__address">
                Training & Education
                <span>click!</span>
            </div>
        </div>
    </section>

    <!-- project Section -->
    <section class="project" id="project" aria-label="프로젝트">
