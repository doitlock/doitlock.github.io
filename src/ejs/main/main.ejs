    @@include('../_templates/_head.ejs')


<body>
    <!-- Header -->
    <header class="header">
        <div class="header__logo">HONG SU KI PORTFOLIO</div>
        <nav>
            <ul class="nav">
                <li class="nav__item"><a href="#about" class="nav__link">ABOUT</a></li>
                <li class="nav__item"><a href="#tech" class="nav__link">TECH STACK</a></li>
                <li class="nav__item"><a href="#project" class="nav__link">PROJECT</a></li>
                <li class="nav__item"><a href="#exhibition" class="nav__link">EXHIBITION</a></li>
                <li class="nav__item"><a href="#event" class="nav__link">EVENT</a></li>
