                        <div class="atom__orbit atom__orbit--1"></div>
                        <div class="atom__orbit atom__orbit--2"></div>
                        <div class="atom__orbit atom__orbit--3"></div>
                    </div>
                    <span class="ai-logo__text">AI NEXT</span>
                </div>
            </div>

            <div class="hero__right">
                <div class="welcome">
                    <div class="welcome__title">WELCOME</div>
                    <div class="welcome__info">
                        Web Publisher · 2021 — 2026
                    </div>
                </div>
            </div>
        </div>

        <div class="hero__main">
            <div class="hero__subtitle">UI DEVELOPER PORTFOLIO</div>
            <h1 class="hero__title">HELLO WOLRD</h1>
        </div>

        <div class="hero__buttons">
            <a href="#" class="btn btn--live" rel="nofollow">▶ GIT HUB</a>
        </div>
